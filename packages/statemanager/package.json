{
  "name": "@theqrl/statemanager",
  "version": "10.1.2",
  "description": "In-memory QRL account, storage, and genesis state manager",
  "keywords": ["qrl", "statemanager", "state"],
  "homepage": "https://github.com/adamtka42/qrljs-monorepo/tree/qrl-adaptation/packages/statemanager#readme",
  "bugs": {
    "url": "https://github.com/adamtka42/qrljs-monorepo/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adamtka42/qrljs-monorepo.git",
    "directory": "packages/statemanager"
  },
  "license": "MPL-2.0",
  "author": "QRL JS contributors",
  "contributors": ["g11tech <gajinder@g11.in>"],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "typescript": "./src/index.ts",
        "default": "./dist/esm/index.js"
      },
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "files": ["dist", "src"],
  "scripts": {
    "biome": "npx @biomejs/biome check",
    "biome:fix": "npx @biomejs/biome check --write",
    "build": "../../config/cli/ts-build.sh",
    "clean": "../../config/cli/clean-package.sh",
    "coverage": "npx vitest run test/qrl -c ../../config/vitest.config.coverage.mts",
    "docs:build": "typedoc --options typedoc.mjs",
    "lint": "npm run biome && eslint  --config ./eslint.config.mjs .",
    "lint:fix": "npm run biome:fix && eslint  --fix --config ./eslint.config.mjs .",
    "prepublishOnly": "../../config/cli/prepublish.sh && npm run test:node",
    "test": "npm run test:qrl",
    "test:node": "npm run test:qrl",
    "test:qrl": "npx vitest run test/qrl -c ../../config/vitest.config.mts",
    "tsc": "../../config/cli/ts-compile.sh"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@theqrl/util": "^10.1.2"
  },
  "devDependencies": {}
}
