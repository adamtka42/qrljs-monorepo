{
  "name": "@theqrl/vm",
  "version": "10.1.2",
  "description": "QRL local VM, provider formatting, block execution, and chain snapshots",
  "keywords": ["qrl", "vm", "local-chain"],
  "homepage": "https://github.com/adamtka42/qrljs-monorepo/tree/qrl-adaptation/packages/vm#readme",
  "bugs": {
    "url": "https://github.com/adamtka42/qrljs-monorepo/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/adamtka42/qrljs-monorepo.git",
    "directory": "packages/vm"
  },
  "license": "MPL-2.0",
  "author": "QRL JS contributors",
  "contributors": ["mjbecze <mjbecze@gmail.com>", "Alex Beregszaszi <alex@rtfs.hu>"],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "typescript": "./src/index.ts",
        "default": "./dist/esm/index.js"
      },
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "files": ["dist", "src"],
  "scripts": {
    "biome": "npx @biomejs/biome check",
    "biome:fix": "npx @biomejs/biome check --write",
    "build": "../../config/cli/ts-build.sh",
    "clean": "../../config/cli/clean-package.sh",
    "coverage": "npx vitest run test/qrl -c ../../config/vitest.config.coverage.mts",
    "docs:build": "typedoc --options typedoc.mjs",
    "lint": "npm run biome && eslint  --config ./eslint.config.mjs .",
    "lint:fix": "npm run biome:fix && eslint  --fix --config ./eslint.config.mjs .",
    "prepublishOnly": "../../config/cli/prepublish.sh && npm run test:buildIntegrity",
    "test": "npm run test:qrl",
    "test:qrl": "npx vitest run test/qrl -c ../../config/vitest.config.mts",
    "tsc": "../../config/cli/ts-compile.sh"
  },
  "dependencies": {
    "@theqrl/block": "^10.1.2",
    "@theqrl/evm": "^10.1.2",
    "@theqrl/statemanager": "^10.1.2",
    "@theqrl/tx": "^10.1.2",
    "@theqrl/util": "^10.1.2"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=20"
  }
}
